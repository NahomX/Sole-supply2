# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used as the magic-link redirect target. For local dev, leave it out or set
# http://localhost:3000. In production, set it to your live URL, e.g.
# https://sole-supply2.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin email whitelist used by the DB trigger to auto-promote accounts
# (see README for the SQL to apply this). Not read by the app directly.
# Example: ADMIN_EMAILS=nahom@example.com,someone-else@example.com
